FLASK_DEBUG=false
HOST=127.0.0.1
PORT=5000

DATA_PROVIDERS=serpapi,demo
DEFAULT_LOCATION=India
DEFAULT_COUNTRY=in
DEFAULT_LANGUAGE=en
RESULT_LIMIT=18
REQUEST_TIMEOUT=20
API_RATE_LIMIT_PER_MINUTE=60
ENABLE_DEMO_FALLBACK=true

SERPAPI_KEY=your_serpapi_key_here
SERPAPI_MAX_PRODUCT_DETAILS=6
SERPAPI_STORE_PAGES=2

DATAFORSEO_LOGIN=your_login_here
DATAFORSEO_PASSWORD=your_password_here
DATAFORSEO_LOCATION_NAME=India
DATAFORSEO_LANGUAGE_NAME=English

MYSQL_ENABLED=true
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=pulse_price_compare
MYSQL_CONNECTION_TIMEOUT=3
